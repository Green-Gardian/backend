# Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=GreenGuardian
DB_PASSWORD=your_password
DB_PORT=5432
DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_here
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRY=5d

# Email Configuration (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
SENDER_EMAIL=onboarding@resend.dev

# Legacy Email Configuration (OAuth - No longer needed with Resend)
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_REFRESH_TOKEN=your_refresh_token
# SENDER_PASSWORD=your_app_password

# SMS Configuration (Vonage)
VONAGE_API_KEY=your_api_key
VONAGE_API_SECRET=your_api_secret
VONAGE_FROM_NUMBER=your_phone_number

# Frontend URL
FRONTEND_URL=http://localhost:5173

# AI Services
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ThingSpeak IoT Configuration
THINGSPEAK_CHANNEL_ID=your_channel_id
THINGSPEAK_READ_API_KEY=your_read_key
THINGSPEAK_FIELD_FILL_LEVEL=1
THINGSPEAK_FIELD_TEMPERATURE=2
THINGSPEAK_FIELD_HUMIDITY=3
THINGSPEAK_FIELD_SMOKE_LEVEL=4
THINGSPEAK_FIELD_LATITUDE=5
THINGSPEAK_FIELD_LONGITUDE=6
FILL_LEVEL_IS_PERCENTAGE=true

# Bin Configuration
BIN_HEIGHT_CM=100
BIN_IOT_POLL_INTERVAL_MS=15000
